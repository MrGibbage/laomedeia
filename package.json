{
  "name": "iptv",
  "private": true,
  "version": "0.1.0",
  "description": "Laomedeia is a modern Windows IPTV viewer for Xtream-compatible providers.",
  "author": "Skip",
  "copyright": "Copyright © 2026 Skip",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder --win --x64",
    "build:unpacked": "tsc && vite build && electron-builder --win --x64 --dir",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "postinstall": "patch-package && electron-rebuild"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "better-sqlite3": "^12.11.1",
    "electron-libmpv": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sax": "^1.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/sax": "^1.2.7",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "patch-package": "^8.0.1",
    "resedit": "^3.0.2",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.6",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "main": "dist-electron/main.js"
}
